# ==============================================================================
# GenAI Stack Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# IMPORTANT: Change all default passwords and keys before production use!
# ==============================================================================

# ------------------------------------------------------------------------------
# Letta
# ------------------------------------------------------------------------------
LETTA_SERVER_PASSWORD=lettapassword

# ------------------------------------------------------------------------------
# n8n
# ------------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=adminpassword

# Encryption key for stored credentials — must be 32+ characters
N8N_ENCRYPTION_KEY=change-me-32-char-encryption-key

# Hostname used for webhook URLs (set to your server's IP/domain in production)
N8N_HOST=localhost

# ------------------------------------------------------------------------------
# InfluxDB (shared with p4n4-iot — must match values in p4n4-iot .env)
# ------------------------------------------------------------------------------
INFLUXDB_TOKEN=p4n4-stack-token
INFLUXDB_ORG=ming
INFLUXDB_BUCKET=raw_telemetry
